# Service Ops Console runtime (copy outside the repository and fill locally)
NODE_ENV=production
OPS_PUBLIC_URL=https://ops.example.com
OPS_BIND_HOST=127.0.0.1
PORT=8787
OPS_DATA_DIR=/var/lib/service-ops-console
OPS_DB_PATH=/var/lib/service-ops-console/service-ops.sqlite
OPS_SESSION_PATH=/var/lib/service-ops-console/sessions
OPS_CONFIG_PATH=/etc/service-ops-console/inventory.json
OPS_SSH_HOSTS_PATH=/etc/service-ops-console/ssh-hosts.json
OPS_CLOUDFLARE_SERVERS_PATH=/etc/service-ops-console/cloudflare.json
OPS_ADMIN_USERNAME=admin
OPS_ADMIN_PASSWORD_HASH=
OPS_SESSION_SECRET=
OPS_SESSION_TTL_DAYS=30
OPS_SESSION_ROLLING=true
OPS_REQUIRE_DASHBOARD_AUTH=true
OPS_ENABLE_PRIVILEGED_OPERATIONS=false
OPS_ENABLE_SERVICE_CONTROL=false
OPS_ENABLE_UPDATE_APPLY=false
OPS_ENABLE_SSH_EXECUTION=false
OPS_ENABLE_CLOUDFLARE_WRITE=false
OPS_STDIO_SCOPES=services:read,services:status,updates:read
OPS_PROBE_CONCURRENCY=8
OPS_UPDATE_CHECK_INTERVAL_MS=0
OPS_UPDATE_CHECK_DAILY_TIME=13:00
OPS_UPDATE_CHECK_TIMEZONE_OFFSET_MINUTES=480

# Secret values are referenced by name from JSON; keep their values in a
# protected EnvironmentFile or secret manager, never in this example.
EXAMPLE_API_HEALTH_AUTHORIZATION=
EXAMPLE_SSH_PRIVATE_KEY=
EXAMPLE_SSH_PASSPHRASE=
EXAMPLE_CLOUDFLARE_ACCESS_TOKEN=
EXAMPLE_CLOUDFLARE_REFRESH_TOKEN=
EXAMPLE_CLOUDFLARE_CLIENT_ID=
EXAMPLE_CLOUDFLARE_CLIENT_SECRET=
